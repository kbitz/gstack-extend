#!/usr/bin/env bash
# gstack-extend setup — install skill symlinks.
#
# Usage:
#   ./setup                                       # Install to ~/.claude/skills/
#   ./setup --uninstall                           # Remove symlinks from default dir
#   ./setup --skills-dir <path> --uninstall       # Remove symlinks from a custom dir
#                                                 # (legacy escape hatch for v0.16.0
#                                                 #  installs; --skills-dir is no
#                                                 #  longer accepted for install)
set -euo pipefail

# bun is the project runtime — required for tests, scripts, and the audit
# binary path. Fail fast at install time so users hit a clear error instead
# of confusing "command not found" later.
if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install with checksum verification:" >&2
  echo '  BUN_VERSION="1.3.10"' >&2
  echo '  tmpfile=$(mktemp)' >&2
  echo '  curl -fsSL "https://bun.sh/install" -o "$tmpfile"' >&2
  echo '  echo "Verify checksum before running: shasum -a 256 $tmpfile"' >&2
  echo '  BUN_VERSION="$BUN_VERSION" bash "$tmpfile" && rm "$tmpfile"' >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
SKILLS_DIR="${HOME}/.claude/skills"
SKILLS_DIR_GIVEN=0
UNINSTALL=0
USAGE="Usage: ./setup [--uninstall] [--skills-dir <path> --uninstall]"

# Source install-safety helpers (is_safe_install_path, is_safe_target_path).
# shellcheck source=bin/lib/install-safety.sh
. "$SCRIPT_DIR/bin/lib/install-safety.sh"

while [ $# -gt 0 ]; do
  case "$1" in
    --uninstall)
      UNINSTALL=1
      shift
      ;;
    --skills-dir)
      # Reject missing value and values that look like a flag
      # (e.g. `./setup --skills-dir --uninstall` would otherwise set
      # SKILLS_DIR to "--uninstall" and fail later inside mkdir).
      # Empty string and any value starting with "-" both fail the guard.
      if [ -z "${2:-}" ] || [ "${2#-}" != "$2" ]; then
        echo "Error: --skills-dir requires a path argument (got: '${2:-<missing>}')" >&2
        echo "$USAGE" >&2
        exit 1
      fi
      # Require an absolute path. Relative paths are interpreted against
      # $PWD at invocation, so running install from one cwd and uninstall
      # from another silently targets a different directory with success
      # exit code. Reject up front.
      if [ "${2#/}" = "$2" ]; then
        echo "Error: --skills-dir requires an absolute path (got: '$2')" >&2
        echo "Hint: use \$(pwd)/$2 if you meant the current directory." >&2
        echo "$USAGE" >&2
        exit 1
      fi
      SKILLS_DIR="$2"
      SKILLS_DIR_GIVEN=1
      shift 2
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "$USAGE" >&2
      exit 1
      ;;
  esac
done

# --skills-dir is now uninstall-only. Pairing it with install was retired
# in Track 5A: skill preambles only probe ~/.claude/skills/{name}/ and
# .claude/skills/{name}/, so symlinks at custom paths are never found.
# Preserved for cleaning up v0.16.0 leftovers via:
#   ./setup --skills-dir <old-custom-dir> --uninstall
if [ "$SKILLS_DIR_GIVEN" -eq 1 ] && [ "$UNINSTALL" -eq 0 ]; then
  echo "Error: --skills-dir is no longer accepted for install." >&2
  echo "  Skill preambles probe ~/.claude/skills/{name}/ and .claude/skills/{name}/." >&2
  echo "  Symlinks at any other path will not be discovered." >&2
  echo "" >&2
  echo "  To clean up a v0.16.0-era custom install, use:" >&2
  echo "    ./setup --skills-dir <old-path> --uninstall" >&2
  echo "" >&2
  echo "$USAGE" >&2
  exit 1
fi

SKILLS=(
  pair-review
  roadmap
  roadmap-new
  full-review
  review-apparatus
  test-plan
)

# Historical skills that prior releases installed. Still iterated on uninstall so
# users upgrading from <0.10.0 get a clean removal of browse-native.
LEGACY_SKILLS=(
  browse-native
)

# ─── Uninstall path ────────────────────────────────────────────
#
# Per-target safety guard: refuse if $target is a symlink to refuse
# operating on a path an attacker may have planted. Uninstalls only the
# symlinks we created (where SKILL.md points at our $SCRIPT_DIR/skills/).
if [ "$UNINSTALL" -eq 1 ]; then
  for skill in "${SKILLS[@]}" "${LEGACY_SKILLS[@]}"; do
    target="$SKILLS_DIR/$skill"
    # Per-target safety: refuse to operate on a symlinked or non-dir
    # $target. Visible skip rather than hard exit so other skills can
    # still uninstall cleanly. is_safe_target_path prints stderr.
    if [ -e "$target" ] || [ -L "$target" ]; then
      if [ -L "$target" ]; then
        echo "Skipped $skill (target is a symlink — refusing to operate on it)"
        continue
      fi
      if [ ! -d "$target" ]; then
        echo "Skipped $skill (target exists but is not a directory)"
        continue
      fi
    else
      # Target doesn't exist at all; nothing to uninstall.
      continue
    fi
    if [ -L "$target/SKILL.md" ]; then
      link_target="$(readlink "$target/SKILL.md" 2>/dev/null || true)"
      expected="$SCRIPT_DIR/skills/${skill}.md"
      if [ "$link_target" = "$expected" ]; then
        rm -f "$target/SKILL.md"
        rmdir "$target" 2>/dev/null || true
        echo "Removed $skill"
      else
        echo "Skipped $skill (symlink points elsewhere)"
      fi
    fi
  done
  echo "Uninstall complete."
  exit 0
fi

# ─── Install path ──────────────────────────────────────────────
#
# Preflight: validate ALL targets before mutating ANY (E8). If skill 3
# fails the safety check, skills 1 and 2 must not be already-installed
# in a partial state.
#
# Layer 1: $SKILLS_DIR (or its nearest existing ancestor) resolves to a
# user-owned, in-$HOME, non-world-writable path. Defends against an
# attacker planting a symlink at ~/.claude/skills.
if ! is_safe_install_path "$SKILLS_DIR"; then
  echo "$USAGE" >&2
  exit 1
fi

# Layer 2: each $SKILLS_DIR/{skill} target is either non-existent or a
# regular directory — never a symlink, never a regular file/FIFO.
for skill in "${SKILLS[@]}"; do
  target="$SKILLS_DIR/$skill"
  src="$SCRIPT_DIR/skills/${skill}.md"
  if [ ! -f "$src" ]; then
    echo "Warning: $src not found, skipping" >&2
    continue
  fi
  if ! is_safe_target_path "$target"; then
    echo "$USAGE" >&2
    exit 1
  fi
  if [ -f "$target/SKILL.md" ] && [ ! -L "$target/SKILL.md" ]; then
    echo "Warning: $target/SKILL.md is a regular file, not overwriting" >&2
    continue
  fi
done

mkdir -p "$SKILLS_DIR"

installed=0
for skill in "${SKILLS[@]}"; do
  src="$SCRIPT_DIR/skills/${skill}.md"
  if [ ! -f "$src" ]; then
    continue
  fi
  target="$SKILLS_DIR/$skill"
  if [ -f "$target/SKILL.md" ] && [ ! -L "$target/SKILL.md" ]; then
    continue
  fi
  mkdir -p "$target"
  ln -snf "$src" "$target/SKILL.md"
  installed=$((installed + 1))
done

echo "Installed $installed skills into $SKILLS_DIR"
