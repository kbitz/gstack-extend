#!/usr/bin/env bash
# gstack-extend setup — install skill symlinks.
#
# Usage:
#   ./setup                                       # Install to ~/.claude/skills/
#   ./setup --uninstall                           # Remove symlinks from default dir
#   ./setup --skills-dir <path> --uninstall       # Remove symlinks from a custom dir
#                                                 # (legacy escape hatch for v0.16.0
#                                                 #  installs; --skills-dir is no
#                                                 #  longer accepted for install)
set -euo pipefail

# bun is the project runtime — required for tests, scripts, and the audit
# binary path. Fail fast at install time so users hit a clear error instead
# of confusing "command not found" later.
if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install with checksum verification:" >&2
  echo '  BUN_VERSION="1.3.10"' >&2
  echo '  tmpfile=$(mktemp)' >&2
  echo '  curl -fsSL "https://bun.sh/install" -o "$tmpfile"' >&2
  echo '  echo "Verify checksum before running: shasum -a 256 $tmpfile"' >&2
  echo '  BUN_VERSION="$BUN_VERSION" bash "$tmpfile" && rm "$tmpfile"' >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
SKILLS_DIR="${HOME}/.claude/skills"
SKILLS_DIR_GIVEN=0
UNINSTALL=0
USAGE="Usage: ./setup [--uninstall] [--skills-dir <path> --uninstall]"

# Source install-safety helpers (is_safe_install_path, is_safe_target_path).
# shellcheck source=bin/lib/install-safety.sh
. "$SCRIPT_DIR/bin/lib/install-safety.sh"

while [ $# -gt 0 ]; do
  case "$1" in
    --uninstall)
      UNINSTALL=1
      shift
      ;;
    --skills-dir)
      # Reject missing value and values that look like a flag
      # (e.g. `./setup --skills-dir --uninstall` would otherwise set
      # SKILLS_DIR to "--uninstall" and fail later inside mkdir).
      # Empty string and any value starting with "-" both fail the guard.
      if [ -z "${2:-}" ] || [ "${2#-}" != "$2" ]; then
        echo "Error: --skills-dir requires a path argument (got: '${2:-<missing>}')" >&2
        echo "$USAGE" >&2
        exit 1
      fi
      # Require an absolute path. Relative paths are interpreted against
      # $PWD at invocation, so running install from one cwd and uninstall
      # from another silently targets a different directory with success
      # exit code. Reject up front.
      if [ "${2#/}" = "$2" ]; then
        echo "Error: --skills-dir requires an absolute path (got: '$2')" >&2
        echo "Hint: use \$(pwd)/$2 if you meant the current directory." >&2
        echo "$USAGE" >&2
        exit 1
      fi
      SKILLS_DIR="$2"
      SKILLS_DIR_GIVEN=1
      shift 2
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "$USAGE" >&2
      exit 1
      ;;
  esac
done

# --skills-dir is now uninstall-only. Pairing it with install was retired
# in Track 5A: skill preambles only probe ~/.claude/skills/{name}/ and
# .claude/skills/{name}/, so symlinks at custom paths are never found.
# Preserved for cleaning up v0.16.0 leftovers via:
#   ./setup --skills-dir <old-custom-dir> --uninstall
if [ "$SKILLS_DIR_GIVEN" -eq 1 ] && [ "$UNINSTALL" -eq 0 ]; then
  echo "Error: --skills-dir is no longer accepted for install." >&2
  echo "  Skill preambles probe ~/.claude/skills/{name}/ and .claude/skills/{name}/." >&2
  echo "  Symlinks at any other path will not be discovered." >&2
  echo "" >&2
  echo "  To clean up a v0.16.0-era custom install, use:" >&2
  echo "    ./setup --skills-dir <old-path> --uninstall" >&2
  echo "" >&2
  echo "$USAGE" >&2
  exit 1
fi

SKILLS=(
  pair-review
  roadmap
  full-review
  review-apparatus
  test-plan
  gstack-extend-upgrade
  gstack-extend-init
)

# Historical skills that prior releases installed. Iterated on every install
# (auto-cleanup of dangling symlinks for retired skills) and on uninstall.
LEGACY_SKILLS=(
  browse-native
  roadmap-new
)

# ─── Uninstall path ────────────────────────────────────────────
#
# Per-target safety guard: refuse if $target is a symlink to refuse
# operating on a path an attacker may have planted. Uninstalls only the
# symlinks we created (where SKILL.md points at our $SCRIPT_DIR/skills/).
if [ "$UNINSTALL" -eq 1 ]; then
  for skill in "${SKILLS[@]}" "${LEGACY_SKILLS[@]}"; do
    target="$SKILLS_DIR/$skill"
    # Per-target safety: refuse to operate on a symlinked or non-dir
    # $target. Visible skip rather than hard exit so other skills can
    # still uninstall cleanly. is_safe_target_path prints stderr.
    if [ -e "$target" ] || [ -L "$target" ]; then
      if [ -L "$target" ]; then
        echo "Skipped $skill (target is a symlink — refusing to operate on it)"
        continue
      fi
      if [ ! -d "$target" ]; then
        echo "Skipped $skill (target exists but is not a directory)"
        continue
      fi
    else
      # Target doesn't exist at all; nothing to uninstall.
      continue
    fi
    if [ -L "$target/SKILL.md" ]; then
      link_target="$(readlink "$target/SKILL.md" 2>/dev/null || true)"
      expected="$SCRIPT_DIR/skills/${skill}.md"
      if [ "$link_target" = "$expected" ]; then
        rm -f "$target/SKILL.md"
        rmdir "$target" 2>/dev/null || true
        echo "Removed $skill"
      else
        echo "Skipped $skill (symlink points elsewhere)"
      fi
    fi
  done

  # ─── CLI symlink uninstall ──────────────────────────────────────────
  # Mirrors the CLI install path below. Only remove if the symlink points
  # at OUR bin — never touch a symlink pointing elsewhere (could be the
  # user's own `gstack-extend` shim or another project's).
  cli_link="$HOME/.local/bin/gstack-extend"
  cli_expected="$SCRIPT_DIR/bin/gstack-extend"
  if [ -L "$cli_link" ]; then
    link_target="$(readlink "$cli_link" 2>/dev/null || true)"
    if [ "$link_target" = "$cli_expected" ]; then
      rm -f "$cli_link"
      echo "Removed gstack-extend CLI symlink ($cli_link)"
    else
      echo "Skipped gstack-extend CLI symlink (points elsewhere: $link_target)"
    fi
  fi

  echo "Uninstall complete."
  exit 0
fi

# ─── Install path ──────────────────────────────────────────────
#
# Preflight: validate ALL targets before mutating ANY (E8). If skill 3
# fails the safety check, skills 1 and 2 must not be already-installed
# in a partial state.
#
# Layer 1: $SKILLS_DIR (or its nearest existing ancestor) resolves to a
# user-owned, in-$HOME, non-world-writable path. Defends against an
# attacker planting a symlink at ~/.claude/skills.
if ! is_safe_install_path "$SKILLS_DIR"; then
  echo "$USAGE" >&2
  exit 1
fi

# Layer 2: each $SKILLS_DIR/{skill} target is either non-existent or a
# regular directory — never a symlink, never a regular file/FIFO.
for skill in "${SKILLS[@]}"; do
  target="$SKILLS_DIR/$skill"
  src="$SCRIPT_DIR/skills/${skill}.md"
  if [ ! -f "$src" ]; then
    echo "Warning: $src not found, skipping" >&2
    continue
  fi
  if ! is_safe_target_path "$target"; then
    echo "$USAGE" >&2
    exit 1
  fi
  if [ -f "$target/SKILL.md" ] && [ ! -L "$target/SKILL.md" ]; then
    echo "Warning: $target/SKILL.md is a regular file, not overwriting" >&2
    continue
  fi
done

mkdir -p "$SKILLS_DIR"

# Auto-clean retired skills so upgrades don't leave dangling symlinks.
# Only removes symlinks we created (target points at our own skills/ dir);
# anything else is left alone.
removed_legacy=0
for skill in "${LEGACY_SKILLS[@]}"; do
  target="$SKILLS_DIR/$skill"
  [ -L "$target/SKILL.md" ] || continue
  link_target="$(readlink "$target/SKILL.md" 2>/dev/null || true)"
  expected_old="$SCRIPT_DIR/skills/${skill}.md"
  if [ "$link_target" = "$expected_old" ]; then
    rm -f "$target/SKILL.md"
    rmdir "$target" 2>/dev/null || true
    removed_legacy=$((removed_legacy + 1))
    echo "Removed retired skill: $skill"
  fi
done

installed=0
for skill in "${SKILLS[@]}"; do
  src="$SCRIPT_DIR/skills/${skill}.md"
  if [ ! -f "$src" ]; then
    continue
  fi
  target="$SKILLS_DIR/$skill"
  if [ -f "$target/SKILL.md" ] && [ ! -L "$target/SKILL.md" ]; then
    continue
  fi
  mkdir -p "$target"
  ln -snf "$src" "$target/SKILL.md"
  installed=$((installed + 1))
done

echo "Installed $installed skills into $SKILLS_DIR"

# ─── CLI symlink wire ────────────────────────────────────────────────
#
# bin/gstack-extend is the project-lifecycle CLI. It must be invokable
# from outside the gstack-extend repo, so we symlink it into a PATH-y
# location. Fail-soft: if ~/.local/bin doesn't exist, print a tip and
# move on — never break the skill install over a missing bin dir.
cli_bin_dir="$HOME/.local/bin"

# Wire one bin into ~/.local/bin/. Fail-soft on every error (missing source,
# missing target dir, non-symlink collision) so a wiring hiccup never breaks
# the rest of the install.
wire_bin() {
  local src="$1"
  local name="$2"
  local dst="$cli_bin_dir/$name"
  if [ ! -f "$src" ] || [ ! -x "$src" ]; then
    return 0  # source missing or not executable — silent skip
  fi
  if [ ! -d "$cli_bin_dir" ]; then
    echo "Tip: ~/.local/bin doesn't exist. Either create it and add to PATH,"
    echo "  or invoke $name directly: $src"
    return 0
  fi
  if [ -e "$dst" ] && [ ! -L "$dst" ]; then
    echo "Warning: $dst exists and is not a symlink; skipping $name wire" >&2
    return 0
  fi
  ln -snf "$src" "$dst"
  echo "Wired $name → $dst"
}

cli_bin_src="$SCRIPT_DIR/bin/gstack-extend"
wire_bin "$cli_bin_src" "gstack-extend"
# Track 13A: telemetry wrapper. Mirrors the gstack-extend wire so the per-skill
# epilogue's `command -v gstack-extend-telemetry` lookup resolves cleanly on
# vendored installs, Conductor workspaces, and CI environments where the
# canonical $HOME/.claude/skills/gstack-extend/bin/ fallback path doesn't hold.
wire_bin "$SCRIPT_DIR/bin/gstack-extend-telemetry" "gstack-extend-telemetry"

# Single PATH-hint after wiring (avoids printing twice for two bins).
if [ -d "$cli_bin_dir" ] && [ -e "$cli_bin_dir/gstack-extend" ]; then
  case ":$PATH:" in
    *":$cli_bin_dir:"*) ;;
    *) echo "  Tip: add $cli_bin_dir to your PATH so wired CLIs resolve directly." ;;
  esac
fi

# ─── Self-registration in projects.json ─────────────────────────────
#
# D4.A: setup auto-writes the gstack-extend repo's own entry into the
# registry the first time it runs after Track 12A ships. Wrapped so a
# registry-write bug never breaks install. --migrate is the right
# subcommand here: gstack-extend repo IS canonically onboarded, just
# not yet registered.
if [ -x "$cli_bin_src" ]; then
  # Capture stderr so a failed self-register reports its first useful
  # line (audit STATUS:fail, permission error, etc.) instead of being
  # silently swallowed and pointing the user at a retry that'll fail
  # the same way.
  _self_register_log=$(mktemp /tmp/gstack-extend-self-register.XXXXXX)
  if "$cli_bin_src" init --migrate --no-prompt "$SCRIPT_DIR" >/dev/null 2>"$_self_register_log"; then
    echo "Self-registered gstack-extend in ~/.gstack-extend/projects.json"
  else
    echo "Note: gstack-extend self-registration skipped (registry write or audit failed)." >&2
    # First non-empty line of stderr — usually the diagnostic the user needs.
    grep -m1 . "$_self_register_log" 2>/dev/null | sed 's/^/  /' >&2 || true
    echo "  Retry: gstack-extend init --migrate $SCRIPT_DIR" >&2
  fi
  rm -f "$_self_register_log"
fi
