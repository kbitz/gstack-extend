#!/usr/bin/env bash
# gstack-extend setup — install skill symlinks.
#
# Usage:
#   ./setup                              # Install to ~/.claude/skills/
#   ./setup --skills-dir <path>          # Install to a custom directory
#   ./setup --uninstall                  # Remove symlinks from default dir
#   ./setup --skills-dir <path> --uninstall
set -euo pipefail

# bun is the project runtime — required for tests, scripts, and the audit
# binary path. Fail fast at install time so users hit a clear error instead
# of confusing "command not found" later.
if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install with checksum verification:" >&2
  echo '  BUN_VERSION="1.3.10"' >&2
  echo '  tmpfile=$(mktemp)' >&2
  echo '  curl -fsSL "https://bun.sh/install" -o "$tmpfile"' >&2
  echo '  echo "Verify checksum before running: shasum -a 256 $tmpfile"' >&2
  echo '  BUN_VERSION="$BUN_VERSION" bash "$tmpfile" && rm "$tmpfile"' >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
SKILLS_DIR="${HOME}/.claude/skills"
UNINSTALL=0
USAGE="Usage: ./setup [--skills-dir <path>] [--uninstall]"

while [ $# -gt 0 ]; do
  case "$1" in
    --uninstall)
      UNINSTALL=1
      shift
      ;;
    --skills-dir)
      # Reject missing value and values that look like a flag
      # (e.g. `./setup --skills-dir --uninstall` would otherwise set
      # SKILLS_DIR to "--uninstall" and fail later inside mkdir).
      # Empty string and any value starting with "-" both fail the guard.
      if [ -z "${2:-}" ] || [ "${2#-}" != "$2" ]; then
        echo "Error: --skills-dir requires a path argument (got: '${2:-<missing>}')" >&2
        echo "$USAGE" >&2
        exit 1
      fi
      # Require an absolute path. Relative paths are interpreted against
      # $PWD at invocation, so running install from one cwd and uninstall
      # from another silently targets a different directory with success
      # exit code. Reject up front.
      if [ "${2#/}" = "$2" ]; then
        echo "Error: --skills-dir requires an absolute path (got: '$2')" >&2
        echo "Hint: use \$(pwd)/$2 if you meant the current directory." >&2
        echo "$USAGE" >&2
        exit 1
      fi
      SKILLS_DIR="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "$USAGE" >&2
      exit 1
      ;;
  esac
done

SKILLS=(
  pair-review
  roadmap
  full-review
  review-apparatus
  test-plan
)

# Historical skills that prior releases installed. Still iterated on uninstall so
# users upgrading from <0.10.0 get a clean removal of browse-native.
LEGACY_SKILLS=(
  browse-native
)

if [ "$UNINSTALL" -eq 1 ]; then
  for skill in "${SKILLS[@]}" "${LEGACY_SKILLS[@]}"; do
    target="$SKILLS_DIR/$skill"
    if [ -d "$target" ] && [ -L "$target/SKILL.md" ]; then
      link_target="$(readlink "$target/SKILL.md" 2>/dev/null || true)"
      expected="$SCRIPT_DIR/skills/${skill}.md"
      if [ "$link_target" = "$expected" ]; then
        rm -f "$target/SKILL.md"
        rmdir "$target" 2>/dev/null || true
        echo "Removed $skill"
      else
        echo "Skipped $skill (symlink points elsewhere)"
      fi
    fi
  done
  echo "Uninstall complete."
  exit 0
fi

mkdir -p "$SKILLS_DIR"

# Known limitation (v0.16.0): skill preambles resolve their helper scripts
# from the hardcoded default ~/.claude/skills/ path. Installs to a custom
# --skills-dir produce working symlinks but the preambles silently no-op
# their update check, config lookup, and audit calls. Pre-flight 2 of
# Group 1 (see docs/ROADMAP.md) ships the probe pattern + rc-file fallback
# that fixes this. Until then, warn loudly so users don't think silence
# means success.
DEFAULT_SKILLS_DIR="${HOME}/.claude/skills"
if [ "$SKILLS_DIR" != "$DEFAULT_SKILLS_DIR" ]; then
  echo "Warning: --skills-dir != default. Skill preambles still hardcode" >&2
  echo "  ~/.claude/skills/{name}/SKILL.md for helper resolution (v0.16.0)." >&2
  echo "  Symlinks will be created at $SKILLS_DIR but skill preambles will" >&2
  echo "  silently skip update-check, config, and audit calls until Group 1" >&2
  echo "  Pre-flight 2 ships. Full per-project support is tracked in" >&2
  echo "  docs/ROADMAP.md." >&2
fi

installed=0
for skill in "${SKILLS[@]}"; do
  src="$SCRIPT_DIR/skills/${skill}.md"
  if [ ! -f "$src" ]; then
    echo "Warning: $src not found, skipping" >&2
    continue
  fi
  target="$SKILLS_DIR/$skill"
  if [ -f "$target/SKILL.md" ] && [ ! -L "$target/SKILL.md" ]; then
    echo "Warning: $target/SKILL.md is a regular file, not overwriting" >&2
    continue
  fi
  mkdir -p "$target"
  ln -snf "$src" "$target/SKILL.md"
  installed=$((installed + 1))
done

echo "Installed $installed skills into $SKILLS_DIR"
