#!/usr/bin/env bash
# gstack-extend roadmap-audit — deterministic doc audit for /roadmap skill.
#
# Scans TODOS.md, PROGRESS.md, VERSION, and CHANGELOG.md for vocabulary drift,
# structural violations, stale items, version mismatches, taxonomy issues,
# doc location opinions, archive candidates, and scattered TODOs.
#
# Output: structured report to stdout with ## CHECK_NAME / STATUS / FINDINGS.
#
# Usage:
#   bin/roadmap-audit [REPO_ROOT]
#
# Env overrides (for testing):
#   GSTACK_EXTEND_DIR — override auto-detected gstack-extend root
set -euo pipefail

EXTEND_DIR="${GSTACK_EXTEND_DIR:-$(cd "$(dirname "$0")/.." && pwd -P)}"
REPO_ROOT="${1:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"

source "$(dirname "$0")/lib/semver.sh"
EXTEND_DIR="$EXTEND_DIR" source "$(dirname "$0")/lib/effort.sh"

# ─── Helpers ──────────────────────────────────────────────────

# find_doc <filename>
# Search root first, then docs/. Print path or empty.
find_doc() {
  local name="$1"
  if [ -f "$REPO_ROOT/$name" ]; then
    echo "$REPO_ROOT/$name"
  elif [ -f "$REPO_ROOT/docs/$name" ]; then
    echo "$REPO_ROOT/docs/$name"
  fi
}

# find_scannable_md_files
# Find all .md files eligible for TODO scanning (maxdepth 2).
# Excludes: known doc types (ROOT_DOCS, DOCS_DIR_DOCS), archived docs.
# Prints one absolute path per line.
find_scannable_md_files() {
  local -a exclude_names=()
  # Combine ROOT_DOCS + DOCS_DIR_DOCS into exclude list
  for doc in "${ROOT_DOCS[@]}"; do exclude_names+=("$doc"); done
  for doc in "${DOCS_DIR_DOCS[@]}"; do exclude_names+=("$doc"); done

  find "$REPO_ROOT" -maxdepth 2 -name '*.md' -type f \
    -not -path '*/node_modules/*' \
    -not -path '*/.git/*' \
    -not -path '*/vendor/*' \
    -not -path '*/docs/archive/*' \
    -not -path '*/.context/*' \
    2>/dev/null | while IFS= read -r filepath; do
      local basename
      basename=$(basename "$filepath")
      local skip=0
      for excluded in "${exclude_names[@]}"; do
        if [ "$basename" = "$excluded" ]; then
          skip=1
          break
        fi
      done
      if [ "$skip" -eq 0 ]; then
        echo "$filepath"
      fi
    done
}

# count_todo_patterns <filepath>
# Count TODO-like patterns in a file, excluding fenced code blocks.
# Patterns: checkboxes, TODO:/FIXME:/HACK:/XXX:, section headings
# (## TODO, ## Tasks, ## Action Items, ## Backlog), and bold+effort markers.
#
# Single-pass awk (NOT per-line bash + grep): on a repo with a large
# CHANGELOG.md + test-roadmap-audit.sh this cuts audit time from ~45s to <1s.
count_todo_patterns() {
  local filepath="$1"
  awk '
    BEGIN { in_code = 0; fence_len = 0; fence_char = "" }
    {
      # Fence line: capture leading ```/~~~ (any length >= 3)
      if (match($0, /^[[:space:]]*(`{3,}|~{3,})/)) {
        fence_raw = substr($0, RSTART, RLENGTH)
        gsub(/[[:space:]]/, "", fence_raw)
        fl = length(fence_raw)
        fc = substr(fence_raw, 1, 1)
        if (in_code == 0) {
          in_code = 1; fence_len = fl; fence_char = fc
        } else if (fc == fence_char && fl >= fence_len) {
          in_code = 0; fence_len = 0; fence_char = ""
        }
        next
      }
      if (in_code == 1) { next }

      # 1. Checkboxes: - [ ] or - [x]
      if ($0 ~ /^[[:space:]]*- \[[ xX]\]/) { count++; next }
      # 2. Inline markers: TODO:|FIXME:|HACK:|XXX:, word-boundary approximated
      #    via non-alnum/start-of-line prefix.
      if ($0 ~ /(^|[^a-zA-Z0-9_])(TODO|FIXME|HACK|XXX):/) { count++; next }
      # 3. Section headings: ## TODO, ## Tasks, ## Action Items, ## Backlog (case-insensitive)
      if (tolower($0) ~ /^#{1,3} (todo|tasks|action items|backlog)/) { count++; next }
      # 4. Bold task + effort marker at end: - **...** ... (S|M|L|XL)
      if ($0 ~ /^[[:space:]]*- \*\*.*\*\*.*\((S|M|L|XL)\)[[:space:]]*$/) { count++; next }
    }
    END { print count + 0 }
  ' "$filepath"
}

TODOS_FILE=$(find_doc "TODOS.md")
ROADMAP_FILE=$(find_doc "ROADMAP.md")
PROGRESS_FILE=$(find_doc "PROGRESS.md")
VERSION_FILE="$REPO_ROOT/VERSION"
CHANGELOG_FILE="$REPO_ROOT/CHANGELOG.md"

# ─── Check 1: Vocabulary Lint ────────────────────────────────

check_vocab_lint() {
  # VOCAB LINT STATE MACHINE
  # ========================
  #                 ┌─────────────┐
  #                 │  TOPLEVEL    │ ◄── default / unknown headings
  #                 │ Phase: BAN  │
  #                 │ (unless     │
  #                 │  title line)│
  #                 └──┬──────┬───┘
  #                    │      │
  #           ^## Group│      │ ^## Future
  #                    ▼      ▼
  #            ┌──────────┐  ┌──────────┐
  #            │  GROUP    │  │  FUTURE   │
  #            │ Phase:BAN │  │ Phase:OK  │
  #            └──┬───┬────┘  └─────┬─────┘
  #               │   │             │
  #      ^## Group│   │^## other    │ ^## other
  #       (stay)  │   │(→TOPLEVEL)  │ (→TOPLEVEL)
  #               ▼   ▼             ▼
  #
  # Phase whitelist (allowed regardless of state):
  #   1. Line matches ^# .*[Pp]hase (ROADMAP.md title)
  #   2. State is FUTURE (inside ## Future section)
  # Phase is BANNED everywhere else.

  echo "## VOCAB_LINT"
  if [ -z "$ROADMAP_FILE" ]; then
    echo "STATUS: skip"
    echo "FINDINGS:"
    echo "- No ROADMAP.md found"
    echo ""
    return
  fi

  local findings=""
  local found=0

  # Unconditionally banned terms (case-insensitive). Scanned via grep.
  local -a banned=("cluster" "workstream" "milestone" "sprint")
  for term in "${banned[@]}"; do
    while IFS= read -r match; do
      local lineno="${match%%:*}"
      local text="${match#*:}"
      # Skip strikethrough lines (completed items)
      if echo "$text" | grep -q '~~'; then
        continue
      fi
      findings="${findings}- line ${lineno}: banned term \"${term}\" found\n"
      found=1
    done < <(grep -in "\b${term}\b" "$ROADMAP_FILE" 2>/dev/null || true)
  done

  # "Phase" — contextual detection via state machine
  local state="TOPLEVEL"
  local lineno=0
  while IFS= read -r line; do
    lineno=$((lineno + 1))

    # State transitions on ## headings
    if echo "$line" | grep -q '^## ' 2>/dev/null; then
      if echo "$line" | grep -qi '^## Group' 2>/dev/null; then
        state="GROUP"
      elif echo "$line" | grep -qiE '^## Future($| \()' 2>/dev/null; then
        state="FUTURE"
      else
        # Any other ## heading (Execution Map, Unprocessed, unknown) → TOPLEVEL
        state="TOPLEVEL"
      fi
    fi

    # Check for "phase" on this line (case-insensitive)
    if echo "$line" | grep -qi '\bphase\b' 2>/dev/null; then
      # Skip strikethrough lines
      if echo "$line" | grep -q '~~'; then
        continue
      fi

      # Whitelist check 1: title line (^# .*Phase)
      if echo "$line" | grep -q '^# .*[Pp]hase' 2>/dev/null; then
        continue
      fi

      # Whitelist check 2: inside FUTURE state
      if [ "$state" = "FUTURE" ]; then
        continue
      fi

      # Everything else: banned
      findings="${findings}- line ${lineno}: banned term \"phase\" found\n"
      found=1
    fi
  done < "$ROADMAP_FILE"

  if [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: fail"
    echo "FINDINGS:"
    echo -e "$findings"
  fi
  echo ""
}

# ─── Check 2: Structure Validation ───────────────────────────

check_structure() {
  echo "## STRUCTURE"
  if [ -z "$ROADMAP_FILE" ]; then
    echo "STATUS: skip"
    echo "FINDINGS:"
    echo "- No ROADMAP.md found"
    echo ""
    return
  fi

  local findings=""
  local found=0

  # Check for Group headings (## Group)
  local group_count
  group_count=$(grep -c '^## Group' "$ROADMAP_FILE" 2>/dev/null || true)
  group_count="${group_count:-0}"
  group_count=$(echo "$group_count" | tr -d '[:space:]')

  # Check for Future section (## Future)
  local has_future=0
  if grep -qiE '^## Future($| \()' "$ROADMAP_FILE" 2>/dev/null; then
    has_future=1
  fi

  # Future-only roadmap is valid (all items deferred to future phase)
  if [ "$group_count" -eq 0 ] && [ "$has_future" -eq 0 ]; then
    findings="${findings}- No Group headings found (expected ## Group N: Name)\n"
    found=1
  fi

  # Check for Track headings (### Track)
  local track_count
  track_count=$(grep -c '^### Track' "$ROADMAP_FILE" 2>/dev/null || true)
  track_count="${track_count:-0}"
  track_count=$(echo "$track_count" | tr -d '[:space:]')

  if [ "$group_count" -gt 0 ] && [ "$track_count" -eq 0 ]; then
    findings="${findings}- Groups found but no Track headings (expected ### Track NA: Name)\n"
    found=1
  fi

  # Check track metadata lines (italic line after ### Track)
  if [ "$track_count" -gt 0 ]; then
    local tracks_with_meta=0
    local in_track=0
    local track_name=""
    while IFS= read -r line; do
      if echo "$line" | grep -q '^### Track' 2>/dev/null; then
        if [ "$in_track" -eq 1 ] && [ -z "$track_name" ]; then
          : # previous track had no metadata, already counted
        fi
        in_track=1
        track_name=$(echo "$line" | sed 's/^### //')
      elif [ "$in_track" -eq 1 ]; then
        # Check if this line is italic metadata (_..._)
        if echo "$line" | grep -qE '^_touches:' 2>/dev/null; then
          # _touches:_ line came first — metadata must come before it.
          findings="${findings}- ${track_name}: _touches:_ line appears before metadata (expected metadata first)\n"
          found=1
        elif echo "$line" | grep -q '^_.*_$' 2>/dev/null; then
          # Validate it has required components: number, risk, files
          if echo "$line" | grep -iq 'risk\|low\|medium\|high' 2>/dev/null; then
            tracks_with_meta=$((tracks_with_meta + 1))
          else
            findings="${findings}- ${track_name}: metadata line missing risk level\n"
            found=1
          fi
        elif [ -n "$line" ]; then
          # Non-empty, non-metadata line after track heading
          findings="${findings}- ${track_name}: missing metadata line (expected _N tasks . effort . risk . files_)\n"
          found=1
        fi
        in_track=0
        track_name=""
      fi
    done < <(cat "$ROADMAP_FILE")
    # Handle last track if it had no metadata
    if [ "$in_track" -eq 1 ] && [ -n "$track_name" ]; then
      findings="${findings}- ${track_name}: missing metadata line (expected _N tasks . effort . risk . files_)\n"
      found=1
    fi
  fi

  if [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: fail"
    echo "FINDINGS:"
    echo -e "$findings"
  fi
  echo ""
}

# ─── Check 3: Staleness Detection ────────────────────────────

check_staleness() {
  echo "## STALENESS"
  if [ -z "$ROADMAP_FILE" ]; then
    echo "STATUS: skip"
    echo "FINDINGS:"
    echo "- No ROADMAP.md found"
    echo ""
    return
  fi

  local findings=""
  local found=0

  # Look for completed-item markers with version patterns
  # Patterns: ~~text~~ DONE (vX.Y.Z), ✓ DONE (vX.Y.Z), ✅ Done, Completed
  local current_version=""
  if [ -f "$VERSION_FILE" ]; then
    current_version=$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]')
  fi

  # Collect all git tags
  local tags=""
  tags=$(git -C "$REPO_ROOT" tag --list 2>/dev/null || true)

  while IFS= read -r match; do
    [ -z "$match" ] && continue
    local lineno="${match%%:*}"
    local text="${match#*:}"

    # Extract version pattern from the line
    local ver=""
    ver=$(echo "$text" | grep -oE '\(v?[0-9]+\.[0-9]+(\.[0-9]+)*\)' 2>/dev/null | head -1 | tr -d '()' | sed 's/^v//' || true)

    if [ -z "$ver" ]; then
      continue
    fi

    # Check if this version has shipped:
    # 1. Check git tags
    local tag_exists=0
    if [ -n "$tags" ]; then
      if echo "$tags" | grep -qE "^v?${ver}$"; then
        tag_exists=1
      fi
    fi

    # 2. Fall back to VERSION file comparison
    local version_shipped=0
    if [ "$tag_exists" -eq 1 ]; then
      version_shipped=1
    elif [ -n "$current_version" ] && [ -n "$ver" ]; then
      # If current version >= completed version, it shipped
      if [ "$current_version" = "$ver" ] || version_gt "$current_version" "$ver"; then
        version_shipped=1
      fi
    fi

    if [ "$version_shipped" -eq 1 ]; then
      findings="${findings}- line ${lineno}: completed item still present (v${ver} shipped) — delete it\n"
      found=1
    fi
  done < <(grep -nE '~~.*DONE|~~.*✓|~~.*✅|~~.*Completed|^### ~~' "$ROADMAP_FILE" 2>/dev/null || true)

  if [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: fail"
    echo "FINDINGS:"
    echo -e "$findings"
  fi
  echo ""
}

# ─── Check 4: Version Audit ──────────────────────────────────

check_version() {
  echo "## VERSION"
  local findings=""
  local found=0

  # Read current version
  local current=""
  if [ -f "$VERSION_FILE" ]; then
    current=$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]')
  else
    echo "STATUS: skip"
    echo "FINDINGS:"
    echo "- No VERSION file found"
    echo ""
    return
  fi

  echo "CURRENT: $current"

  # Check for invalid version format (3 or 4 segments: X.Y.Z or X.Y.Z.W)
  if ! echo "$current" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+(\.[0-9]+)?$'; then
    findings="${findings}- VERSION \"${current}\" is not valid (expected X.Y.Z or X.Y.Z.W)\n"
    found=1
  fi

  # Latest git tag
  local latest_tag=""
  latest_tag=$(git -C "$REPO_ROOT" --no-pager tag --list --sort=-v:refname 2>/dev/null | head -1 || true)
  if [ -n "$latest_tag" ]; then
    echo "LATEST_TAG: $latest_tag"
    local tag_ver
    tag_ver=$(echo "$latest_tag" | sed 's/^v//')
    if [ "$current" != "$tag_ver" ]; then
      findings="${findings}- VERSION (${current}) does not match latest tag (${latest_tag})\n"
      found=1
    fi
  else
    echo "LATEST_TAG: (none)"
    findings="${findings}- No git tags found — consider tagging releases (git tag vX.Y.Z)\n"
    found=1
  fi

  # PROGRESS.md latest version (highest by semver, not table order)
  if [ -n "$PROGRESS_FILE" ] && [ -f "$PROGRESS_FILE" ]; then
    local progress_ver=""
    while IFS= read -r candidate; do
      candidate=$(echo "$candidate" | tr -d '| ')
      [ -z "$candidate" ] && continue
      # Keep the highest version (3 or 4 segments both valid)
      if [ -z "$progress_ver" ] || version_gt "$candidate" "$progress_ver"; then
        progress_ver="$candidate"
      fi
    done < <(grep -oE '\| [0-9]+\.[0-9]+(\.[0-9]+)*(\.[0-9]+)* \|' "$PROGRESS_FILE" 2>/dev/null || true)
    if [ -n "$progress_ver" ]; then
      echo "PROGRESS_LATEST: $progress_ver"
    fi
  fi

  # CHANGELOG.md latest version
  if [ -f "$CHANGELOG_FILE" ]; then
    local changelog_ver=""
    changelog_ver=$(grep -oE '## \[?[0-9]+\.[0-9]+\.[0-9]+(\.[0-9]+)?' "$CHANGELOG_FILE" 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+(\.[0-9]+)?' || true)
    if [ -n "$changelog_ver" ]; then
      echo "CHANGELOG_LATEST: $changelog_ver"
    fi
  fi

  # Recommend bump type based on changes since last tag
  local recommend="none"
  if [ -n "$latest_tag" ]; then
    local code_changed
    code_changed=$(git -C "$REPO_ROOT" --no-pager diff --name-only "$latest_tag"..HEAD 2>/dev/null | grep -cvE '\.(md|txt|yml|yaml|json)$' || true)
    code_changed="${code_changed:-0}"
    code_changed=$(echo "$code_changed" | tr -d '[:space:]')
    if [ "$code_changed" -gt 0 ]; then
      recommend="patch"
    fi
  fi
  echo "RECOMMEND: $recommend"

  if [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: fail"
    echo "FINDINGS:"
    echo -e "$findings"
  fi
  echo ""
}

# ─── Check 5: Taxonomy ───────────────────────────────────────

check_taxonomy() {
  echo "## TAXONOMY"
  local findings=""
  local found=0

  # Check expected docs exist
  if [ -z "$TODOS_FILE" ]; then
    findings="${findings}- TODOS.md: missing (inbox for unprocessed items)\n"
    found=1
  fi
  if [ -z "$ROADMAP_FILE" ]; then
    findings="${findings}- ROADMAP.md: missing (run /roadmap to create from TODOS.md)\n"
    found=1
  fi
  if [ -z "$PROGRESS_FILE" ]; then
    findings="${findings}- PROGRESS.md: missing\n"
    found=1
  fi
  if [ ! -f "$VERSION_FILE" ]; then
    findings="${findings}- VERSION: missing\n"
    found=1
  fi

  # Check for duplicate docs (both root and docs/)
  if [ -f "$REPO_ROOT/TODOS.md" ] && [ -f "$REPO_ROOT/docs/TODOS.md" ]; then
    findings="${findings}- TODOS.md exists in both root and docs/ — should be in docs/ only\n"
    found=1
  fi
  if [ -f "$REPO_ROOT/ROADMAP.md" ] && [ -f "$REPO_ROOT/docs/ROADMAP.md" ]; then
    findings="${findings}- ROADMAP.md exists in both root and docs/ — should be in docs/ only\n"
    found=1
  fi
  if [ -f "$REPO_ROOT/PROGRESS.md" ] && [ -f "$REPO_ROOT/docs/PROGRESS.md" ]; then
    findings="${findings}- PROGRESS.md exists in both root and docs/ — should be in docs/ only\n"
    found=1
  fi

  # Exact-match overlap detection between PROGRESS.md and CHANGELOG.md
  if [ -n "$PROGRESS_FILE" ] && [ -f "$CHANGELOG_FILE" ]; then
    local overlap_count=0
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      # Skip table headers and separators
      if echo "$line" | grep -qE '^\|[-]+' 2>/dev/null; then continue; fi
      if echo "$line" | grep -qE '^\| Version' 2>/dev/null; then continue; fi
      if grep -qF "$line" "$CHANGELOG_FILE" 2>/dev/null; then
        overlap_count=$((overlap_count + 1))
      fi
    done < <(grep -E '^\|' "$PROGRESS_FILE" 2>/dev/null || true)

    if [ "$overlap_count" -gt 3 ]; then
      findings="${findings}- PROGRESS.md and CHANGELOG.md share ${overlap_count} identical lines — possible content duplication\n"
      found=1
    fi
  fi

  if [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: fail"
    echo "FINDINGS:"
    echo -e "$findings"
  fi
  echo ""
}

# ─── Check 6: Doc Location ──────────────────────────────────
#
# Opinionated check: which docs belong in root vs docs/.
#
#   Root (repo conventions):  README.md, CHANGELOG.md, CLAUDE.md, VERSION, LICENSE
#   docs/ (project artifacts): TODOS.md, ROADMAP.md, PROGRESS.md, designs/, archive/
#

# Docs that should live in root (tools/platforms expect them there)
ROOT_DOCS=("README.md" "CHANGELOG.md" "CLAUDE.md" "VERSION" "LICENSE" "LICENSE.md")
# Docs that should live in docs/
DOCS_DIR_DOCS=("TODOS.md" "ROADMAP.md" "PROGRESS.md")

check_doc_location() {
  echo "## DOC_LOCATION"
  local findings=""
  local found=0

  # Check if docs/ directory exists
  local has_docs_dir=0
  [ -d "$REPO_ROOT/docs" ] && has_docs_dir=1

  # Check docs/-destined files that are in root instead
  for doc in "${DOCS_DIR_DOCS[@]}"; do
    if [ -f "$REPO_ROOT/$doc" ] && [ ! -f "$REPO_ROOT/docs/$doc" ]; then
      if [ "$has_docs_dir" -eq 1 ]; then
        findings="${findings}- ${doc} is in root — should be in docs/\n"
        found=1
      else
        findings="${findings}- ${doc} is in root — consider creating docs/ and moving it there\n"
        found=1
      fi
    fi
  done

  # Check root-destined files that are only in docs/ (wrong direction)
  for doc in "${ROOT_DOCS[@]}"; do
    if [ -f "$REPO_ROOT/docs/$doc" ] && [ ! -f "$REPO_ROOT/$doc" ]; then
      findings="${findings}- ${doc} is in docs/ — should be in root (tools/platforms expect it there)\n"
      found=1
    fi
  done

  if [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: fail"
    echo "FINDINGS:"
    echo -e "$findings"
  fi
  echo ""
}

# ─── Check 7: Archive Candidates ────────────────────────────
#
# Flags design docs in docs/designs/ that reference a version
# that has already shipped (version <= current VERSION).
# These are candidates for archiving to docs/archive/.
#

check_archive_candidates() {
  echo "## ARCHIVE_CANDIDATES"
  local findings=""
  local found=0

  # Need VERSION to compare against
  if [ ! -f "$VERSION_FILE" ]; then
    echo "STATUS: skip"
    echo "FINDINGS:"
    echo "- No VERSION file — cannot detect archive candidates"
    echo ""
    return
  fi

  local current_ver
  current_ver=$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]')

  # Need docs/designs/ to scan
  if [ ! -d "$REPO_ROOT/docs/designs" ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
    echo ""
    return
  fi

  # Scan each design doc for version references
  for design_file in "$REPO_ROOT"/docs/designs/*.md; do
    [ -f "$design_file" ] || continue
    local basename
    basename=$(basename "$design_file")

    # Extract version references (e.g., v0.3.0, v1.0.0, 0.5.0)
    local doc_ver
    doc_ver=$(grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' "$design_file" 2>/dev/null | head -1 | sed 's/^v//' || true)

    if [ -z "$doc_ver" ]; then
      # No version reference — skip this doc
      continue
    fi

    # Compare: if doc version <= current version, it's a candidate for archiving
    if semver_lte "$doc_ver" "$current_ver"; then
      findings="${findings}- docs/designs/${basename} references v${doc_ver} (current: v${current_ver}) — candidate for archiving to docs/archive/\n"
      found=1
    fi
  done

  if [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: fail"
    echo "FINDINGS:"
    echo -e "$findings"
  fi
  echo ""
}

# ─── Check 8: Dependency Integrity ───────────────────────────

check_dependencies() {
  echo "## DEPENDENCIES"
  if [ -z "$ROADMAP_FILE" ]; then
    echo "STATUS: skip"
    echo "FINDINGS:"
    echo "- No ROADMAP.md found"
    echo ""
    return
  fi

  # Collect all track names
  local -a tracks=()
  while IFS= read -r line; do
    local name
    name=$(echo "$line" | sed 's/^### //' | sed 's/:.*//')
    tracks+=("$name")
  done < <(grep '^### Track' "$ROADMAP_FILE" 2>/dev/null || true)

  # Find Depends on: lines that reference Track patterns
  local findings=""
  local found=0
  local has_deps=0

  while IFS= read -r match; do
    [ -z "$match" ] && continue
    has_deps=1
    local lineno="${match%%:*}"
    local text="${match#*:}"

    # Extract track references (Track [0-9A-Z]+)
    while IFS= read -r ref; do
      [ -z "$ref" ] && continue
      # Check if this track exists
      local exists=0
      for t in "${tracks[@]}"; do
        if echo "$t" | grep -q "$ref"; then
          exists=1
          break
        fi
      done
      if [ "$exists" -eq 0 ]; then
        findings="${findings}- line ${lineno}: references \"${ref}\" but no such track exists\n"
        found=1
      fi
    done < <(echo "$text" | grep -oE 'Track [0-9]+[A-Z]' || true)
  done < <(grep -n 'Depends on:' "$ROADMAP_FILE" 2>/dev/null || true)

  if [ "$has_deps" -eq 0 ]; then
    echo "STATUS: skip"
    echo "FINDINGS:"
    echo "- No Depends on: lines found"
  elif [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: fail"
    echo "FINDINGS:"
    echo -e "$findings"
  fi
  echo ""
}

# ─── Check 7: Unprocessed Section + Mode Detection ───────────

check_unprocessed() {
  echo "## UNPROCESSED"
  if [ -z "$TODOS_FILE" ]; then
    echo "STATUS: skip"
    echo "ITEMS: 0"
    echo "FINDINGS:"
    echo "- No TODOS.md found"
    echo ""
    return
  fi

  # Check if ## Unprocessed section exists
  local has_section=0
  local item_count=0
  local in_section=0

  while IFS= read -r line; do
    if echo "$line" | grep -q '^## Unprocessed' 2>/dev/null; then
      has_section=1
      in_section=1
      continue
    fi
    # Stop at the next ## heading
    if [ "$in_section" -eq 1 ] && echo "$line" | grep -q '^## ' 2>/dev/null; then
      in_section=0
      continue
    fi
    # Count non-empty lines starting with - in the section
    if [ "$in_section" -eq 1 ] && echo "$line" | grep -q '^- ' 2>/dev/null; then
      item_count=$((item_count + 1))
    fi
  done < <(cat "$TODOS_FILE")

  echo "ITEMS: $item_count"

  if [ "$has_section" -eq 1 ] && [ "$item_count" -gt 0 ]; then
    echo "STATUS: found"
    echo "FINDINGS:"
    echo "- ${item_count} unprocessed items awaiting triage"
  elif [ "$has_section" -eq 1 ]; then
    echo "STATUS: empty"
    echo "FINDINGS:"
    echo "- Unprocessed section exists but is empty"
  else
    echo "STATUS: none"
    echo "FINDINGS:"
    echo "- No Unprocessed section"
  fi
  echo ""
}

# ─── Mode Detection ──────────────────────────────────────────

detect_mode() {
  echo "## MODE"
  if [ -z "$ROADMAP_FILE" ]; then
    echo "DETECTED: overhaul"
    echo "REASON: No ROADMAP.md found"
    echo ""
    return
  fi

  # Check if Groups > Tracks structure exists in ROADMAP.md
  local group_count
  group_count=$(grep -c '^## Group' "$ROADMAP_FILE" 2>/dev/null || true)
  group_count="${group_count:-0}"
  group_count=$(echo "$group_count" | tr -d '[:space:]')

  # Check for Future section
  local has_future=0
  if grep -qiE '^## Future($| \()' "$ROADMAP_FILE" 2>/dev/null; then
    has_future=1
  fi

  if [ "$group_count" -gt 0 ]; then
    echo "DETECTED: triage"
    echo "REASON: Valid Groups > Tracks structure found (${group_count} groups)"
  elif [ "$has_future" -eq 1 ]; then
    echo "DETECTED: triage"
    echo "REASON: Future-only roadmap found (all items deferred to future phase)"
  else
    echo "DETECTED: overhaul"
    echo "REASON: No Groups > Tracks structure found"
  fi
  echo ""
}

# ─── Check 9: Task List ─────────────────────────────────────
#
# Parses ROADMAP.md and outputs a structured list of all tasks.
# Used by the skill prompt during reorg to avoid LLM-based extraction.
# Output: one TASK line per task with group, track, title, effort, files.
#

check_task_list() {
  echo "## TASK_LIST"

  local roadmap
  roadmap=$(find_doc "ROADMAP.md")
  if [ -z "$roadmap" ]; then
    echo "STATUS: skip"
    echo "TOTAL_TASKS: 0"
    echo "TOTAL_CURRENT: 0"
    echo "TOTAL_FUTURE: 0"
    echo ""
    return
  fi

  local section="none"
  local group_num=""
  local track_id=""
  local total_tasks=0
  local total_current=0
  local total_future=0
  local in_preflight=0

  echo "STATUS: info"

  while IFS= read -r line; do
    # Group heading: ## Group N: Name
    if echo "$line" | grep -qE '^## Group [0-9]+:'; then
      group_num=$(echo "$line" | sed -E 's/^## Group ([0-9]+):.*/\1/')
      section="group"
      in_preflight=0
      track_id=""
      continue
    fi

    # Pre-flight heading
    if echo "$line" | grep -qiE '^\*\*Pre-flight\*\*'; then
      in_preflight=1
      track_id="preflight"
      section="preflight"
      continue
    fi

    # Track heading: ### Track NA: Name
    if echo "$line" | grep -qE '^### Track [0-9]+[A-Z]:'; then
      track_id=$(echo "$line" | sed -E 's/^### Track ([0-9]+[A-Z]):.*/\1/')
      section="track"
      in_preflight=0
      continue
    fi

    # Future section
    if echo "$line" | grep -qiE '^## Future'; then
      section="future"
      group_num="future"
      track_id="none"
      in_preflight=0
      continue
    fi

    # Unprocessed section — stop parsing
    if echo "$line" | grep -qiE '^## Unprocessed'; then
      break
    fi

    # Execution Map section — skip (not tasks)
    if echo "$line" | grep -qiE '^## Execution Map'; then
      section="skip"
      continue
    fi

    # Any other ## heading — reset section
    if echo "$line" | grep -qE '^## '; then
      section="none"
      continue
    fi

    # Skip if we're in a non-task section
    if [ "$section" = "none" ] || [ "$section" = "skip" ]; then
      continue
    fi

    # Task line: starts with - ** (bold title)
    if echo "$line" | grep -qE '^- \*\*'; then
      local title effort files

      # Extract title: first **...** segment
      title=$(echo "$line" | sed -E 's/^- \*\*([^*]+)\*\*.*/\1/')

      # Extract effort: trailing (S), (M), (L), (XL)
      effort=$(echo "$line" | grep -oE '\((S|M|L|XL)\)$' | tr -d '()' || true)
      [ -z "$effort" ] && effort="?"

      # Extract files: from italic _[files],_ or _[files]._
      files=$(echo "$line" | sed -nE 's/.*_\[([^]]+)\].*/\1/p')
      [ -z "$files" ] && files=""

      local g="${group_num:-0}"
      local t="${track_id:-none}"

      echo "TASK: group=${g}|track=${t}|title=${title}|effort=${effort}|files=${files}"
      total_tasks=$((total_tasks + 1))
      if [ "$section" = "future" ]; then
        total_future=$((total_future + 1))
      else
        total_current=$((total_current + 1))
      fi
      continue
    fi

    # Pre-flight task line: starts with - (no bold) in preflight section
    if [ "$in_preflight" -eq 1 ] && echo "$line" | grep -qE '^- [^*]'; then
      local title
      title=$(echo "$line" | sed 's/^- //')

      echo "TASK: group=${group_num:-0}|track=preflight|title=${title}|effort=S|files="
      total_tasks=$((total_tasks + 1))
      total_current=$((total_current + 1))
      continue
    fi

  done < "$roadmap"

  echo "TOTAL_TASKS: $total_tasks"
  echo "TOTAL_CURRENT: $total_current"
  echo "TOTAL_FUTURE: $total_future"
  echo ""
}

# ─── Check 10: Structural Fitness ──────────────────────────────
#
# Computes structural metrics from ROADMAP.md: tasks per group,
# tracks per group, imbalance ratio. Informational output consumed
# by the skill prompt's structural assessment (Step 3-pre).
#

check_structural_fitness() {
  echo "## STRUCTURAL_FITNESS"

  local roadmap
  roadmap=$(find_doc "ROADMAP.md")
  if [ -z "$roadmap" ]; then
    echo "STATUS: skip"
    echo ""
    return
  fi

  local group_count=0
  local track_count=0
  local task_count=0
  local current_group=""
  local current_track=""
  local section="none"
  local in_preflight=0

  # Bash 3-compatible key=value storage (no associative arrays)
  # Format: "key1=val1 key2=val2 ..."
  # _kv_get/_kv_set/_kv_keys are defined at module scope — see Check 13.
  local group_task_counts=""
  local track_task_counts=""

  while IFS= read -r line; do
    # Group heading
    if echo "$line" | grep -qE '^## Group [0-9]+:'; then
      current_group=$(echo "$line" | sed -E 's/^## Group ([0-9]+):.*/\1/')
      group_count=$((group_count + 1))
      group_task_counts=$(_kv_set "$group_task_counts" "$current_group" 0)
      section="group"
      in_preflight=0
      current_track=""
      continue
    fi

    # Track heading
    if echo "$line" | grep -qE '^### Track [0-9]+[A-Z]:'; then
      current_track=$(echo "$line" | sed -E 's/^### Track ([0-9]+[A-Z]):.*/\1/')
      track_count=$((track_count + 1))
      track_task_counts=$(_kv_set "$track_task_counts" "$current_track" 0)
      section="track"
      in_preflight=0
      continue
    fi

    # Pre-flight
    if echo "$line" | grep -qiE '^\*\*Pre-flight\*\*'; then
      in_preflight=1
      section="preflight"
      continue
    fi

    # Future / Unprocessed / Execution Map — stop counting
    if echo "$line" | grep -qiE '^## (Future|Unprocessed|Execution Map)'; then
      break
    fi

    # Task line (bold title)
    if [ "$section" != "none" ] && echo "$line" | grep -qE '^- \*\*'; then
      task_count=$((task_count + 1))
      if [ -n "$current_group" ]; then
        local cur=$(_kv_get "$group_task_counts" "$current_group")
        group_task_counts=$(_kv_set "$group_task_counts" "$current_group" $(( ${cur:-0} + 1 )))
      fi
      if [ "$in_preflight" -eq 0 ] && [ -n "$current_track" ]; then
        local cur=$(_kv_get "$track_task_counts" "$current_track")
        track_task_counts=$(_kv_set "$track_task_counts" "$current_track" $(( ${cur:-0} + 1 )))
      fi
      continue
    fi

    # Pre-flight task (no bold)
    if [ "$in_preflight" -eq 1 ] && echo "$line" | grep -qE '^- [^*]'; then
      task_count=$((task_count + 1))
      if [ -n "$current_group" ]; then
        local cur=$(_kv_get "$group_task_counts" "$current_group")
        group_task_counts=$(_kv_set "$group_task_counts" "$current_group" $(( ${cur:-0} + 1 )))
      fi
      continue
    fi

  done < "$roadmap"

  echo "STATUS: info"
  echo "GROUP_COUNT: $group_count"
  echo "TRACK_COUNT: $track_count"
  echo "TASK_COUNT: $task_count"

  # Group sizes
  if [ "$group_count" -gt 0 ]; then
    local sizes=""
    for g in $(_kv_keys "$group_task_counts"); do
      local val=$(_kv_get "$group_task_counts" "$g")
      [ -n "$sizes" ] && sizes="${sizes},"
      sizes="${sizes}${g}=${val}"
    done
    echo "GROUP_SIZES: $sizes"

    # Track sizes
    if [ "$track_count" -gt 0 ]; then
      local tsizes=""
      for t in $(_kv_keys "$track_task_counts"); do
        local val=$(_kv_get "$track_task_counts" "$t")
        [ -n "$tsizes" ] && tsizes="${tsizes},"
        tsizes="${tsizes}${t}=${val}"
      done
      echo "TRACK_SIZES: $tsizes"
    fi

    # Imbalance ratio (max/min, only if 2+ groups)
    if [ "$group_count" -ge 2 ]; then
      local max_size=0
      local min_size=999999
      for g in $(_kv_keys "$group_task_counts"); do
        local s=$(_kv_get "$group_task_counts" "$g")
        [ "$s" -gt "$max_size" ] && max_size=$s
        [ "$s" -lt "$min_size" ] && min_size=$s
      done
      if [ "$min_size" -gt 0 ]; then
        local ratio_int=$((max_size * 100 / min_size))
        local ratio_whole=$((ratio_int / 100))
        local ratio_frac=$((ratio_int % 100))
        printf "IMBALANCE_RATIO: %d.%02d\n" "$ratio_whole" "$ratio_frac"
      else
        echo "IMBALANCE_RATIO: inf"
      fi
    fi
  fi

  echo ""
}

# ─── Check 11: Doc Inventory ─────────────────────────────────
#
# Lists all .md files found in the repo with TODO-pattern counts
# and whether they are a known doc type. Informational output
# consumed by the skill prompt for Step 1.5 (Doc Discovery).
#

check_doc_inventory() {
  echo "## DOC_INVENTORY"
  local file_count=0
  local files_output=""

  # Known doc types for labeling (bash 3 compatible)
  _is_root_doc() {
    for doc in "${ROOT_DOCS[@]}"; do [ "$doc" = "$1" ] && return 0; done
    return 1
  }
  _is_project_doc() {
    for doc in "${DOCS_DIR_DOCS[@]}"; do [ "$doc" = "$1" ] && return 0; done
    return 1
  }

  # Scan all .md files (including known ones, for inventory)
  while IFS= read -r filepath; do
    [ -z "$filepath" ] && continue
    local basename
    basename=$(basename "$filepath")
    local relpath="${filepath#$REPO_ROOT/}"

    local todo_count
    todo_count=$(count_todo_patterns "$filepath")

    local doc_type="unknown"
    if _is_root_doc "$basename"; then
      doc_type="root doc"
    elif _is_project_doc "$basename"; then
      doc_type="project doc"
    elif echo "$filepath" | grep -q '/docs/designs/' 2>/dev/null; then
      doc_type="design doc"
    elif echo "$filepath" | grep -q '/docs/archive/' 2>/dev/null; then
      doc_type="archived doc"
    fi

    files_output="${files_output}- ${relpath}: ${todo_count} TODO patterns (${doc_type})\n"
    file_count=$((file_count + 1))
  done < <(find "$REPO_ROOT" -maxdepth 2 -name '*.md' -type f \
    -not -path '*/node_modules/*' \
    -not -path '*/.git/*' \
    -not -path '*/vendor/*' \
    -not -path '*/docs/archive/*' \
    -not -path '*/.context/*' \
    2>/dev/null | sort)

  echo "STATUS: info"
  echo "FILES:"
  if [ "$file_count" -gt 0 ]; then
    echo -e "$files_output"
  else
    echo "- (none)"
  fi
  echo "TOTAL_FILES: $file_count"
  echo ""
}

# ─── Check 12: Scattered TODOs ─────────────────────────────
#
# Flags non-standard .md files that contain TODO-like patterns.
# These are candidates for extraction by the skill prompt.
#

check_scattered_todos() {
  echo "## SCATTERED_TODOS"
  local findings=""
  local found=0
  local total_scattered=0

  while IFS= read -r filepath; do
    [ -z "$filepath" ] && continue
    local relpath="${filepath#$REPO_ROOT/}"

    local todo_count
    todo_count=$(count_todo_patterns "$filepath")

    if [ "$todo_count" -gt 0 ]; then
      findings="${findings}- ${relpath}: ${todo_count} items\n"
      total_scattered=$((total_scattered + todo_count))
      found=1
    fi
  done < <(find_scannable_md_files)

  if [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: found"
    echo "FINDINGS:"
    echo -e "$findings"
  fi
  echo "TOTAL_SCATTERED: $total_scattered"
  echo ""
}

# ─── Check 13: Size, Collisions, Style Lint (parse + emit) ────
#
# Rev 0.9.0 additions. Parse ROADMAP.md once into per-track state,
# then run size, collision, and style checks against that state.
# Shared infra is loaded once from docs/shared-infra.txt.
#
# See docs/designs/... or ceo-plans for the rationale.

# Module-level parser state (populated by _parse_roadmap).
_ROADMAP_PARSED=0
_TRACK_LIST=""           # space-sep track IDs: "1A 1B 2A"
_TRACK_GROUP=""          # kv: "1A=1 1B=1 2A=2"
_TRACK_TOUCHES=""        # kv: "1A=setup,bin/foo 1B=... 2A="   (empty = legacy)
_TRACK_TASKS=""          # kv: "1A=3 1B=2"
_TRACK_LOC=""            # kv: "1A=250 1B=150"
_TRACK_FILES_COUNT=""    # kv: "1A=2 1B=3" (count of files in touches)
_TRACK_LEGACY=""         # kv: "1A=0 1B=1" (1 = no _touches:_ line)
_GROUP_LIST=""           # space-sep group numbers: "1 2"
_GROUP_TRACKS=""         # kv: "1=1A,1B 2=2A"
_SIZE_LABEL_MISMATCHES=""  # newline-sep "TrackID|title|effort|declared|expected"
_STYLE_LINT_WARNINGS=""    # newline-sep "TrackID: depends on TrackYY (same Group N)"

# kv helpers — promoted to module scope for reuse across checks.
# Format: "key1=val1 key2=val2 ...". Bash 3 compatible (no assoc arrays).
# Trailing `|| true` so that a no-match grep doesn't kill the script under
# `set -eo pipefail` when these run inside command substitution.
_kv_get() { echo "$1" | tr ' ' '\n' | { grep "^$2=" || true; } | tail -1 | cut -d= -f2; }
_kv_set() { printf '%s ' "$1" | tr ' ' '\n' | { grep -v "^$2=" || true; } | tr '\n' ' '; printf "%s=%s" "$2" "$3"; }
_kv_keys() { echo "$1" | tr ' ' '\n' | { grep '=' || true; } | cut -d= -f1 | sort -u; }

# Trim leading/trailing whitespace from a string.
_trim() {
  local s="$1"
  # shellcheck disable=SC2001
  s=$(echo "$s" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
  echo "$s"
}

# Extract the count from a "~N lines" hint, or empty if none.
_extract_lines_hint() {
  echo "$1" | grep -oE '~[0-9]+[[:space:]]*lines?' | head -1 | grep -oE '[0-9]+' || true
}

# _parse_roadmap
# Single-pass parse of ROADMAP.md. Populates _TRACK_*/_GROUP_* state and
# the label-mismatch / style-lint finding lists. Idempotent (runs once).
_parse_roadmap() {
  if [ "$_ROADMAP_PARSED" -eq 1 ]; then
    return 0
  fi
  _ROADMAP_PARSED=1

  local roadmap
  roadmap=$(find_doc "ROADMAP.md")
  if [ -z "$roadmap" ]; then
    return 0
  fi

  local section="none"
  local group_num=""
  local track_id=""

  while IFS= read -r line || [ -n "$line" ]; do
    # Top-level sections that end per-track scoping.
    if echo "$line" | grep -qiE '^## (Future|Unprocessed|Execution Map)'; then
      section="skip"
      track_id=""
      continue
    fi

    # Group heading: ## Group N: Name
    if echo "$line" | grep -qE '^## Group [0-9]+:'; then
      group_num=$(echo "$line" | sed -E 's/^## Group ([0-9]+):.*/\1/')
      if ! echo " $_GROUP_LIST " | grep -q " $group_num "; then
        _GROUP_LIST="${_GROUP_LIST}${_GROUP_LIST:+ }${group_num}"
      fi
      section="group"
      track_id=""
      continue
    fi

    # Any other ## heading — reset
    if echo "$line" | grep -qE '^## '; then
      section="none"
      track_id=""
      continue
    fi

    # Pre-flight block within a Group — per-Group trivial bucket.
    if echo "$line" | grep -qiE '^\*\*Pre-flight\*\*'; then
      section="preflight"
      track_id=""
      continue
    fi

    # Track heading: ### Track NA: Name
    if echo "$line" | grep -qE '^### Track [0-9]+[A-Z]:'; then
      track_id=$(echo "$line" | sed -E 's/^### Track ([0-9]+[A-Z]):.*/\1/')
      if echo " $_TRACK_LIST " | grep -q " $track_id "; then
        # Duplicate track ID — earlier state gets stomped by kv_set. Warn.
        _STYLE_LINT_WARNINGS="${_STYLE_LINT_WARNINGS}${track_id}: duplicate track ID (another track earlier in ROADMAP.md also uses '${track_id}') — rename one; track IDs must be globally unique\n"
      else
        _TRACK_LIST="${_TRACK_LIST}${_TRACK_LIST:+ }${track_id}"
      fi
      _TRACK_GROUP=$(_kv_set "$_TRACK_GROUP" "$track_id" "${group_num:-0}")
      _TRACK_TOUCHES=$(_kv_set "$_TRACK_TOUCHES" "$track_id" "")
      _TRACK_TASKS=$(_kv_set "$_TRACK_TASKS" "$track_id" 0)
      _TRACK_LOC=$(_kv_set "$_TRACK_LOC" "$track_id" 0)
      _TRACK_FILES_COUNT=$(_kv_set "$_TRACK_FILES_COUNT" "$track_id" 0)
      _TRACK_LEGACY=$(_kv_set "$_TRACK_LEGACY" "$track_id" 1)  # assume legacy until we see _touches:_
      # Append to group's track list
      if [ -n "$group_num" ]; then
        local cur
        cur=$(_kv_get "$_GROUP_TRACKS" "$group_num")
        if [ -n "$cur" ]; then
          _GROUP_TRACKS=$(_kv_set "$_GROUP_TRACKS" "$group_num" "${cur},${track_id}")
        else
          _GROUP_TRACKS=$(_kv_set "$_GROUP_TRACKS" "$group_num" "$track_id")
        fi
      fi
      section="track"
      in_preflight=0
      expecting_touches=1  # metadata line comes next; after that, maybe _touches:_
      continue
    fi

    # Within a track, check for _touches:_ line (can appear after metadata).
    # The italic metadata line is skipped here — check_structure validates it.
    if [ -n "$track_id" ] && [ "$section" = "track" ]; then
      # _touches: <comma-sep files>_
      if echo "$line" | grep -qE '^_touches:'; then
        local raw
        raw=$(echo "$line" | sed -E 's/^_touches:[[:space:]]*//; s/_[[:space:]]*$//')
        # Split, trim, drop empties. Reject tokens containing whitespace or
        # `=` — these corrupt the kv store downstream.
        local touches_list=""
        local files_count=0
        local malformed=0
        local IFS_ORIG="$IFS"
        IFS=','
        for f in $raw; do
          local ft
          ft=$(_trim "$f")
          if [ -z "$ft" ]; then
            continue
          fi
          # Reject internal whitespace or `=` — our kv store uses space/= as separators.
          if echo "$ft" | grep -qE '[[:space:]=]'; then
            malformed=1
            continue
          fi
          touches_list="${touches_list}${touches_list:+,}${ft}"
          files_count=$((files_count + 1))
        done
        IFS="$IFS_ORIG"

        # Empty/whitespace-only _touches:_ MUST NOT silently promote to modern
        # (that would disable the collision check for this track). Keep legacy.
        if [ "$files_count" -eq 0 ]; then
          _STYLE_LINT_WARNINGS="${_STYLE_LINT_WARNINGS}${track_id}: _touches:_ line is empty or whitespace-only — track remains legacy (add file paths to opt into SIZE/COLLISIONS checks)\n"
          continue
        fi
        if [ "$malformed" -eq 1 ]; then
          _STYLE_LINT_WARNINGS="${_STYLE_LINT_WARNINGS}${track_id}: _touches:_ contained tokens with whitespace or '=' — those entries were dropped (kv-store limitation)\n"
        fi
        _TRACK_TOUCHES=$(_kv_set "$_TRACK_TOUCHES" "$track_id" "$touches_list")
        _TRACK_FILES_COUNT=$(_kv_set "$_TRACK_FILES_COUNT" "$track_id" "$files_count")
        _TRACK_LEGACY=$(_kv_set "$_TRACK_LEGACY" "$track_id" 0)
        continue
      fi

      # Same-group Depends on: Track NA — style lint (warning, not fail).
      # Match any "Depends on: Track <ID>" in the track body. Flag if that
      # referenced ID starts with the same group digits.
      if echo "$line" | grep -qiE 'Depends on:[[:space:]]*Track [0-9]+[A-Z]'; then
        local dep_id
        dep_id=$(echo "$line" | grep -oiE 'Track [0-9]+[A-Z]' | head -1 | sed -E 's/^Track //')
        if [ "$dep_id" = "$track_id" ]; then
          _STYLE_LINT_WARNINGS="${_STYLE_LINT_WARNINGS}${track_id}: Depends on itself (Track ${dep_id}) — typo or stale reference?\n"
        else
          local dep_group
          dep_group=$(echo "$dep_id" | grep -oE '^[0-9]+')
          local track_group
          track_group=$(echo "$track_id" | grep -oE '^[0-9]+')
          if [ -n "$dep_group" ] && [ "$dep_group" = "$track_group" ]; then
            _STYLE_LINT_WARNINGS="${_STYLE_LINT_WARNINGS}${track_id}: Depends on Track ${dep_id} (same Group ${track_group}) — tracks in a Group must be fully parallel-safe; move to next Group\n"
          fi
        fi
      fi
    fi

    # Task line within a track — update task/loc/files-count + label cross-check.
    if [ -n "$track_id" ] && [ "$section" = "track" ] && echo "$line" | grep -qE '^- \*\*'; then
      local title effort declared_lines expected_loc
      title=$(echo "$line" | sed -E 's/^- \*\*([^*]+)\*\*.*/\1/')
      effort=$(echo "$line" | grep -oE '\((S|M|L|XL)\)[[:space:]]*$' | tr -d '() ' || true)
      declared_lines=$(_extract_lines_hint "$line")

      local cur_tasks cur_loc
      cur_tasks=$(_kv_get "$_TRACK_TASKS" "$track_id")
      cur_loc=$(_kv_get "$_TRACK_LOC" "$track_id")

      _TRACK_TASKS=$(_kv_set "$_TRACK_TASKS" "$track_id" $(( ${cur_tasks:-0} + 1 )))

      if [ -n "$effort" ]; then
        expected_loc=$(effort_to_loc "$effort")
        _TRACK_LOC=$(_kv_set "$_TRACK_LOC" "$track_id" $(( ${cur_loc:-0} + expected_loc )))
        # Label mismatch: declared "~N lines" diverges from effort tier by >3x
        # Guard: both values must be positive integers (avoid /0 when declared_lines is 0).
        if [ -n "$declared_lines" ] && [ "$declared_lines" -gt 0 ] && [ "$expected_loc" -gt 0 ]; then
          local ratio_num ratio_den
          if [ "$declared_lines" -gt "$expected_loc" ]; then
            ratio_num=$declared_lines; ratio_den=$expected_loc
          else
            ratio_num=$expected_loc; ratio_den=$declared_lines
          fi
          # >3x divergence
          if [ "$ratio_num" -gt $(( ratio_den * 3 )) ]; then
            _SIZE_LABEL_MISMATCHES="${_SIZE_LABEL_MISMATCHES}${track_id}|${title}|${effort}|${declared_lines}|${expected_loc}\n"
          fi
        fi
      fi
    fi

  done < "$roadmap"
}

# load_shared_infra
# Read docs/shared-infra.txt (if present), expand patterns via find -path,
# populate _SHARED_INFRA_FILES (newline-sep relative paths).
# Supports: literal paths, * (matches any chars incl /), ** (no special
# meaning — treated as *), and {a,b} brace expansion (via bash).
_SHARED_INFRA_LOADED=0
_SHARED_INFRA_FILES=""
_SHARED_INFRA_STATUS="missing"
load_shared_infra() {
  if [ "$_SHARED_INFRA_LOADED" -eq 1 ]; then
    return 0
  fi
  _SHARED_INFRA_LOADED=1

  local f="$REPO_ROOT/docs/shared-infra.txt"
  if [ ! -f "$f" ]; then
    _SHARED_INFRA_STATUS="missing"
    return 0
  fi
  _SHARED_INFRA_STATUS="loaded"

  local -a all_matches=()
  while IFS= read -r raw_pat || [ -n "$raw_pat" ]; do
    # Strip comments and blanks.
    local pat
    pat=$(echo "$raw_pat" | sed 's/#.*//')
    pat=$(_trim "$pat")
    if [ -z "$pat" ]; then
      continue
    fi

    # Brace expansion without path-glob: disable pathname expansion, let
    # bash do brace expansion only, collect words into an array, re-enable
    # pathname expansion. Each expanded word goes through find -path.
    #
    # Security: validate the pattern against a strict whitelist before eval.
    # shared-infra.txt is project-owned, but a malicious pattern would otherwise
    # execute via eval. Only allow characters needed for paths/globs/braces.
    if ! echo "$pat" | grep -qE '^[a-zA-Z0-9/._{}*,+-]+$'; then
      echo "SHARED_INFRA_WARN: skipping pattern with unsafe characters: '$pat'" >&2
      continue
    fi
    # Reject `..` (path traversal) and `{..` (brace range expansion, which
    # can produce arbitrarily large outputs like {1..1000000000}).
    if echo "$pat" | grep -qE '\.\.'; then
      echo "SHARED_INFRA_WARN: skipping pattern containing '..': '$pat'" >&2
      continue
    fi
    # Keep pathname expansion disabled throughout: disable at expand time
    # AND during the for-loop (word splitting of `$_expansion` would otherwise
    # re-glob against CWD). Cap expanded word count to defend against
    # brace-expansion bombs like {a,b}{c,d}{e,f}... (exponential) or
    # {1..1000000} (range). 1000 is generous for real patterns.
    local p
    local expand_count=0
    local expand_cap=1000
    set -f
    local _expansion
    # shellcheck disable=SC2086
    _expansion=$(eval "echo $pat")
    # shellcheck disable=SC2086
    for p in $_expansion; do
      expand_count=$((expand_count + 1))
      if [ "$expand_count" -gt "$expand_cap" ]; then
        echo "SHARED_INFRA_WARN: pattern '$pat' expanded past $expand_cap entries — truncating" >&2
        break
      fi
      # find -path uses absolute pattern; prefix with REPO_ROOT.
      local full="$REPO_ROOT/$p"
      local match
      while IFS= read -r match; do
        if [ -z "$match" ]; then
          continue
        fi
        local rel="${match#$REPO_ROOT/}"
        all_matches+=("$rel")
      done < <(find "$REPO_ROOT" -path "$full" -type f 2>/dev/null)
    done
    set +f
  done < "$f"

  # Deduplicate + sort.
  if [ ${#all_matches[@]} -gt 0 ]; then
    _SHARED_INFRA_FILES=$(printf '%s\n' "${all_matches[@]}" | sort -u)
  fi
}

# _is_shared_infra <relpath>
# 0 if path is in the loaded shared-infra set, 1 otherwise.
_is_shared_infra() {
  if [ -z "$_SHARED_INFRA_FILES" ]; then
    return 1
  fi
  echo "$_SHARED_INFRA_FILES" | grep -Fxq -- "$1"
}

# ─── Check: SIZE ──────────────────────────────────────────────
# Enforces per-track size caps on modern tracks (those with _touches:_).
# Legacy tracks are skipped with a banner. Also emits SIZE_LABEL_MISMATCH
# warnings for tasks whose declared `~N lines` diverges from their
# effort tier's LOC mapping by >3x.
check_size_caps() {
  echo "## SIZE"
  _parse_roadmap

  if [ -z "$_TRACK_LIST" ]; then
    echo "STATUS: skip"
    echo "FINDINGS:"
    echo "- No tracks found"
    echo ""
    return
  fi

  local max_tasks max_loc max_files
  max_tasks=$(ceiling max_tasks_per_track)
  max_loc=$(ceiling max_loc_per_track)
  max_files=$(ceiling max_files_per_track)

  local findings=""
  local mismatch_findings=""
  local found=0
  local legacy_tracks=""
  local modern_count=0

  local t
  for t in $_TRACK_LIST; do
    local is_legacy
    is_legacy=$(_kv_get "$_TRACK_LEGACY" "$t")
    if [ "${is_legacy:-1}" = "1" ]; then
      legacy_tracks="${legacy_tracks}${legacy_tracks:+,}${t}"
      continue
    fi
    modern_count=$((modern_count + 1))

    local tasks loc files
    tasks=$(_kv_get "$_TRACK_TASKS" "$t")
    loc=$(_kv_get "$_TRACK_LOC" "$t")
    files=$(_kv_get "$_TRACK_FILES_COUNT" "$t")
    tasks=${tasks:-0}
    loc=${loc:-0}
    files=${files:-0}

    if [ "$tasks" -gt "$max_tasks" ]; then
      findings="${findings}- ${t}: tasks=${tasks} exceeds max_tasks_per_track=${max_tasks}\n"
      found=1
    fi
    if [ "$loc" -gt "$max_loc" ]; then
      findings="${findings}- ${t}: loc=${loc} exceeds max_loc_per_track=${max_loc}\n"
      found=1
    fi
    if [ "$files" -gt "$max_files" ]; then
      findings="${findings}- ${t}: files=${files} exceeds max_files_per_track=${max_files}\n"
      found=1
    fi
  done

  # Emit label mismatch findings separately (informational, not blocking).
  if [ -n "$_SIZE_LABEL_MISMATCHES" ]; then
    mismatch_findings=$(printf "%b" "$_SIZE_LABEL_MISMATCHES" | while IFS='|' read -r tid title effort decl exp; do
      if [ -z "$tid" ]; then
        continue
      fi
      echo "- ${tid} \"${title}\": effort=(${effort}) implies ~${exp} LOC, declared ~${decl} lines (>3x divergence)"
    done)
  fi

  if [ "$found" -eq 0 ] && [ "$modern_count" -eq 0 ]; then
    echo "STATUS: skip-legacy-all"
    echo "FINDINGS:"
    echo "- All tracks are legacy (no _touches:_ metadata) — run /roadmap to migrate"
  elif [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: fail"
    echo "FINDINGS:"
    echo -e "$findings"
  fi

  if [ -n "$mismatch_findings" ]; then
    echo "SIZE_LABEL_MISMATCH:"
    echo "$mismatch_findings"
  fi

  echo "MAX_TASKS_PER_TRACK: $max_tasks"
  echo "MAX_LOC_PER_TRACK: $max_loc"
  echo "MAX_FILES_PER_TRACK: $max_files"
  if [ -n "$legacy_tracks" ]; then
    echo "LEGACY_TRACKS: $legacy_tracks"
  fi
  echo ""
}

# ─── Check: COLLISIONS ─────────────────────────────────────────
# For each Group, compute the pairwise intersection of every modern
# track's _touches:_ set. Non-empty intersection = audit blocker.
# Classifies each collision as SHARED_INFRA (overlap is in shared-infra
# set — fix is "promote to Pre-flight") or PARALLEL (otherwise — fix is
# "merge tracks or split into next Group").
check_collisions() {
  echo "## COLLISIONS"
  _parse_roadmap
  load_shared_infra

  if [ -z "$_GROUP_LIST" ]; then
    echo "STATUS: skip"
    echo "FINDINGS:"
    echo "- No Groups found"
    echo ""
    return
  fi

  local findings=""
  local found=0
  local max_tracks_per_group
  max_tracks_per_group=$(ceiling max_tracks_per_group)
  local group_size_warnings=""

  local g
  for g in $_GROUP_LIST; do
    local tracks_csv
    tracks_csv=$(_kv_get "$_GROUP_TRACKS" "$g")
    if [ -z "$tracks_csv" ]; then
      continue
    fi

    # Split tracks by comma.
    local IFS_ORIG="$IFS"
    IFS=','
    local -a tracks=()
    for tid in $tracks_csv; do
      # Only include modern tracks (legacy excluded from pairing).
      local is_legacy
      is_legacy=$(_kv_get "$_TRACK_LEGACY" "$tid")
      if [ "${is_legacy:-1}" = "0" ]; then
        tracks+=("$tid")
      fi
    done
    IFS="$IFS_ORIG"

    # Enforce max tracks per Group cap.
    if [ ${#tracks[@]} -gt "$max_tracks_per_group" ]; then
      group_size_warnings="${group_size_warnings}- Group ${g}: ${#tracks[@]} modern tracks exceeds max_tracks_per_group=${max_tracks_per_group}\n"
      found=1
    fi

    # Pairwise intersection check.
    local i j
    for (( i=0; i<${#tracks[@]}; i++ )); do
      for (( j=i+1; j<${#tracks[@]}; j++ )); do
        local a="${tracks[$i]}"
        local b="${tracks[$j]}"
        local a_touches b_touches
        a_touches=$(_kv_get "$_TRACK_TOUCHES" "$a")
        b_touches=$(_kv_get "$_TRACK_TOUCHES" "$b")
        if [ -z "$a_touches" ] || [ -z "$b_touches" ]; then
          continue
        fi

        # Compute intersection as newline-sep list of shared files.
        local a_sorted b_sorted intersection
        a_sorted=$(echo "$a_touches" | tr ',' '\n' | sort -u)
        b_sorted=$(echo "$b_touches" | tr ',' '\n' | sort -u)
        intersection=$(comm -12 <(echo "$a_sorted") <(echo "$b_sorted"))

        if [ -n "$intersection" ]; then
          # Classify by shared-infra membership of any overlapping file.
          local classification="PARALLEL"
          local f
          while IFS= read -r f; do
            if [ -z "$f" ]; then
              continue
            fi
            if _is_shared_infra "$f"; then
              classification="SHARED_INFRA"
              break
            fi
          done <<< "$intersection"

          local intersect_flat
          intersect_flat=$(echo "$intersection" | tr '\n' ',' | sed 's/,$//')
          findings="${findings}- ${a}-${b}: [${intersect_flat}] [${classification}]\n"
          found=1
        fi
      done
    done
  done

  if [ "$found" -eq 0 ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: fail"
    echo "FINDINGS:"
    echo -e "$findings"
  fi
  if [ -n "$group_size_warnings" ]; then
    echo "GROUP_SIZE_WARNINGS:"
    echo -e "$group_size_warnings"
  fi
  echo "MAX_TRACKS_PER_GROUP: $max_tracks_per_group"
  echo "SHARED_INFRA_STATUS: $_SHARED_INFRA_STATUS"
  echo ""
}

# ─── Check: STYLE_LINT ─────────────────────────────────────────
# Warning (not fail) for intra-Group `Depends on: Track NA` references.
# Tracks inside the same Group must be fully parallel-safe — if one
# depends on another, the dependent belongs in a later Group.
check_style_lint() {
  echo "## STYLE_LINT"
  _parse_roadmap

  if [ -z "$_STYLE_LINT_WARNINGS" ]; then
    echo "STATUS: pass"
    echo "FINDINGS:"
    echo "- (none)"
  else
    echo "STATUS: warn"
    echo "FINDINGS:"
    echo -e "$_STYLE_LINT_WARNINGS"
  fi
  echo ""
}

# ─── Run all checks ──────────────────────────────────────────

check_vocab_lint
check_structure
check_staleness
check_version
check_taxonomy
check_doc_location
check_archive_candidates
check_dependencies
check_task_list
