#!/bin/sh
# gstack-extend roadmap-audit — TS implementation, run via bun.
# Behavior-preserving cutover from the bash original (now retired).
# Source of truth: src/audit/cli.ts. The legacy bash binary is preserved
# in git history (see CHANGELOG / Track 2B); this shim is the single
# entry point going forward.
exec bun "$(dirname "$0")/../src/audit/cli.ts" "$@"
