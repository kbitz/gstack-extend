#!/usr/bin/env bash
# roadmap-place — emit ranked placement candidates for a kept inbox item.
#
# This helper does feature engineering and rule application; it does NOT make
# semantic judgment calls. When the situation has one clean answer (origin
# in-flight, no-origin+primary, drained roadmap), it emits one candidate.
# When the situation requires judgment the helper can't make (file overlap
# is semantic, not literal string match), it emits multiple ranked candidates
# and skill prose picks using LLM judgment over context the helper can't see.
#
# Inputs (flags; everything optional except --tag):
#   --tag <source-tag>           e.g. '[pair-review:group=2,item=5]'
#   --in-flight "1 2"            space-sep list of in-flight Group numbers
#   --complete "3"               space-sep list of ✓ Complete Group numbers
#   --primary "1"                primary in-flight Group (first by doc order)
#   --severity critical          override severity (else parsed from tag)
#   --files "auth.ts,api.ts"     comma-sep file paths from item description
#   --primary-touches "ui/**,api.ts"  comma-sep _touches:_ of primary in-flight Group
#
# Output (KEY=VALUE on stdout, blocks separated by blank lines):
#   candidates=N           number of candidates that follow
#
#   --- candidate 1 (rank=1, recommended) ---
#   rank=1
#   target=current|future|hotfix
#   group=N            (current/hotfix only; absent for future)
#   slot=preflight|track   (current only)
#   reason=<one-line rationale>
#   needs_judgment=0|1     (1 = prose should apply LLM judgment to confirm/override)
#
#   --- candidate 2, 3, ... ---
#   ...
#
# Semantics:
#   - candidates=1 with needs_judgment=0 → unambiguous, prose can use directly.
#   - candidates>=2 → prose MUST apply judgment to pick (typically file-overlap
#     semantics or off-topic detection that the helper can't do).
#   - needs_judgment=1 on a single candidate → prose should sanity-check before
#     using (e.g., off-topic items might warrant deferral despite the rule).
#
# Exit code: 0 always.

set -euo pipefail

source "$(dirname "$0")/lib/source-tag.sh"

TAG=""
IN_FLIGHT=""
COMPLETE=""
PRIMARY=""
SEVERITY_OVERRIDE=""
FILES=""
PRIMARY_TOUCHES=""

while [ $# -gt 0 ]; do
  case "$1" in
    --tag) TAG="${2:-}"; shift 2 ;;
    --in-flight) IN_FLIGHT="${2:-}"; shift 2 ;;
    --complete) COMPLETE="${2:-}"; shift 2 ;;
    --primary) PRIMARY="${2:-}"; shift 2 ;;
    --severity) SEVERITY_OVERRIDE="${2:-}"; shift 2 ;;
    --files) FILES="${2:-}"; shift 2 ;;
    --primary-touches) PRIMARY_TOUCHES="${2:-}"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; exit 1 ;;
  esac
done

# Parse the tag for group hint and severity.
GROUP_HINT=""
SEVERITY=""
SOURCE=""
if [ -n "$TAG" ] && [ "$TAG" != "[]" ]; then
  PARSED=$(parse_source_tag "$TAG" 2>/dev/null) || true
  SOURCE=$(echo "$PARSED" | grep -E '^source=' | head -1 | cut -d= -f2 || true)
  GROUP_HINT=$(echo "$PARSED" | grep -E '^group=' | head -1 | cut -d= -f2 || true)
  SEVERITY=$(echo "$PARSED" | grep -E '^severity=' | head -1 | cut -d= -f2 || true)
fi
[ -n "$SEVERITY_OVERRIDE" ] && SEVERITY="$SEVERITY_OVERRIDE"

_in_list() {
  local needle="$1"; local hay="$2"
  echo " $hay " | grep -q " $needle "
}

_emit_candidate() {
  # Args: rank, target, group (or empty), slot (or empty), reason, needs_judgment
  echo "rank=$1"
  echo "target=$2"
  [ -n "$3" ] && echo "group=$3"
  [ -n "$4" ] && echo "slot=$4"
  echo "reason=$5"
  echo "needs_judgment=$6"
  echo ""
}

# Origin-tagged item (group=N hint present): route back to its origin Group.
if [ -n "$GROUP_HINT" ]; then
  if _in_list "$GROUP_HINT" "$IN_FLIGHT"; then
    echo "candidates=1"
    echo ""
    _emit_candidate 1 "current" "$GROUP_HINT" "track" \
      "origin Group $GROUP_HINT is in-flight — fold back into the Group that surfaced this item" \
      0
    exit 0
  fi
  if _in_list "$GROUP_HINT" "$COMPLETE"; then
    # Reopen rule for items whose origin Group already shipped.
    if [ "$SEVERITY" = "critical" ]; then
      echo "candidates=1"
      echo ""
      _emit_candidate 1 "hotfix" "$GROUP_HINT" "" \
        "critical severity on shipped Group — append as hotfix to Group $GROUP_HINT" \
        0
      exit 0
    fi
    # Origin-complete + non-critical: this is the judgment-bearing case.
    # The helper emits TWO candidates and lets skill prose decide via LLM
    # semantic-overlap judgment. Literal string match was the old shortcut
    # and missed semantic overlaps (e.g., 'auth/login.tsx' vs 'ui/auth/**').
    if [ -n "$PRIMARY" ]; then
      echo "candidates=2"
      echo ""
      _emit_candidate 1 "current" "$PRIMARY" "track" \
        "if item's files semantically overlap primary Group $PRIMARY's _touches:_ ($PRIMARY_TOUCHES) — fold into active work" \
        1
      _emit_candidate 2 "future" "" "" \
        "if item is off-topic for active Group $PRIMARY — shipped Group $GROUP_HINT is immutable, defer to Future" \
        1
      exit 0
    fi
    # No primary in-flight Group → only deferral makes sense.
    echo "candidates=1"
    echo ""
    _emit_candidate 1 "future" "" "" \
      "origin Group $GROUP_HINT shipped, no in-flight Group to fold into — defer to Future" \
      0
    exit 0
  fi
  # Group hint references a Group that doesn't exist (renamed/deleted).
  echo "candidates=1"
  echo ""
  _emit_candidate 1 "future" "" "" \
    "origin Group $GROUP_HINT not found in current roadmap (renamed/deleted) — defer to Future for explicit re-classification" \
    1
  exit 0
fi

# No origin hint: default to current phase, primary in-flight Group's Pre-flight.
# Marked needs_judgment=1 so prose checks the item is on-topic for the primary
# Group before placing — this is where "off-topic but no-origin" items can sneak in.
if [ -n "$PRIMARY" ]; then
  echo "candidates=1"
  echo ""
  _emit_candidate 1 "current" "$PRIMARY" "preflight" \
    "no origin tag — default placement is primary in-flight Group $PRIMARY's Pre-flight" \
    1
  exit 0
fi

# No in-flight Groups at all (drained roadmap or future-only state).
echo "candidates=1"
echo ""
_emit_candidate 1 "future" "" "" \
  "no in-flight Group available to place item — defer to Future for next overhaul" \
  0
