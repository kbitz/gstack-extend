#!/usr/bin/env bash
# gstack-extend update-run — perform the actual upgrade.
#
# Usage:
#   bin/update-run <repo-root>
#
# The repo root is passed from the skill preamble (resolved via readlink).
# This avoids hardcoding paths and works regardless of where the repo is cloned.
#
# Output:
#   UPGRADE_OK <old> <new>     — upgrade succeeded
#   UPGRADE_FAILED <reason>    — upgrade failed
set -euo pipefail

INSTALL_DIR="${1:-}"
STATE_DIR="${GSTACK_EXTEND_STATE_DIR:-$HOME/.gstack-extend}"

if [ -z "$INSTALL_DIR" ]; then
  echo "UPGRADE_FAILED missing repo root argument"
  exit 1
fi

if [ ! -d "$INSTALL_DIR/.git" ]; then
  echo "UPGRADE_FAILED not a git repo: $INSTALL_DIR"
  exit 1
fi

# ─── Step 1: Save old version ─────────────────────────────────
OLD_VERSION=$(cat "$INSTALL_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")

# ─── Step 2: Upgrade via git ──────────────────────────────────
mkdir -p "$STATE_DIR"

PREV_BRANCH=$(git -C "$INSTALL_DIR" branch --show-current 2>/dev/null || true)
STASH_OUTPUT=$(git -C "$INSTALL_DIR" stash 2>&1)
git -C "$INSTALL_DIR" fetch origin

# Switch to main if on a different branch
if [ -n "$PREV_BRANCH" ] && [ "$PREV_BRANCH" != "main" ]; then
  git -C "$INSTALL_DIR" checkout main
  echo "Note: switched from branch '$PREV_BRANCH' to main for upgrade."
fi

# Fast-forward only — if main has diverged locally, fail safely instead of destroying work
if ! git -C "$INSTALL_DIR" pull --ff-only origin main; then
  # Restore previous branch if we switched
  if [ -n "$PREV_BRANCH" ] && [ "$PREV_BRANCH" != "main" ]; then
    git -C "$INSTALL_DIR" checkout "$PREV_BRANCH" 2>/dev/null || true
  fi
  # Restore stashed changes
  if echo "$STASH_OUTPUT" | grep -q "Saved working directory"; then
    git -C "$INSTALL_DIR" stash pop 2>/dev/null || true
  fi
  echo "UPGRADE_FAILED local main has diverged from origin/main (ff-only failed)"
  exit 1
fi

"$INSTALL_DIR/setup"

# Switch back to previous branch if we moved away
if [ -n "$PREV_BRANCH" ] && [ "$PREV_BRANCH" != "main" ]; then
  git -C "$INSTALL_DIR" checkout "$PREV_BRANCH" 2>/dev/null || true
fi

# Restore stashed changes on the original branch (best-effort)
if echo "$STASH_OUTPUT" | grep -q "Saved working directory"; then
  if ! git -C "$INSTALL_DIR" stash pop 2>/dev/null; then
    echo "Note: local changes were stashed but could not be restored. Run 'git -C $INSTALL_DIR stash pop' manually."
  fi
fi

# ─── Step 3: Write upgrade marker ─────────────────────────────
NEW_VERSION=$(cat "$INSTALL_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")
echo "$OLD_VERSION" > "$STATE_DIR/just-upgraded-from"

# Clear cache so next check is fresh
rm -f "$STATE_DIR/last-update-check"
rm -f "$STATE_DIR/update-snoozed"

echo "UPGRADE_OK $OLD_VERSION $NEW_VERSION"
